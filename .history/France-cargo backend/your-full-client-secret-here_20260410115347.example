# Database (SQLite - no setup needed!)
DATABASE_URL=sqlite+aiosqlite:///./francecargo.db

# JWT Secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=change-this-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google OAuth 2.0
GOOGLE_CLIENT_ID=299372414908-njjrmfbo6n7riasesq5pk5qeqq36nhel.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-full-client-secret-here

# Frontend
FRONTEND_URL=http://localhost:3000